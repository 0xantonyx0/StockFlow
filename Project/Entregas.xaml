<Page x:Class="StockFlow.Entregas"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:StockFlow"
      mc:Ignorable="d"
      Title="Entregas" d:DesignHeight="650" d:DesignWidth="1150" Background="White">

    <Page.Resources>
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#A8B7C5"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="25,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#2A3F54">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="70"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="60"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                    <TextBlock Text="📦" FontSize="24" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="STOCKFLOW" FontSize="18" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,10">
                    <Button Content="🏠  Dashboard" Style="{StaticResource MenuButtonStyle}"/>
                    <Button Content="📋  Inventário" Style="{StaticResource MenuButtonStyle}" Background="#34495E" Foreground="White"/>
                    <Button Content="📥  Entradas" Style="{StaticResource MenuButtonStyle}"/>
                    <Button Content="📤  Saídas" Style="{StaticResource MenuButtonStyle}"/>
                    <Button Content="📊  Relatórios" Style="{StaticResource MenuButtonStyle}"/>
                </StackPanel>

                <Button Grid.Row="2" Content="⚙️  Configurações" Style="{StaticResource MenuButtonStyle}" VerticalAlignment="Bottom"/>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,20">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Inventário de Produtos" FontSize="26" FontWeight="Bold" Foreground="#2A3F54"/>
                    <TextBlock Text="Lista global de itens em estoque" FontSize="12" Foreground="Gray" Margin="0,2,0,0"/>
                </StackPanel>

                <Button Content="+ Adicionar Produto" HorizontalAlignment="Right" Padding="15,8" 
                        Background="#3498DB" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
            </Grid>

            <DataGrid Grid.Row="2" x:Name="dtgdados" AutoGenerateColumns="False" IsReadOnly="True"
                      Background="White" RowBackground="White" AlternatingRowBackground="#F9FAFC" 
                      BorderBrush="#E2E8F0" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#E2E8F0"
                      RowHeight="40" FontSize="12" Foreground="#333333">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F4F7FC"/>
                        <Setter Property="Foreground" Value="#5A738E"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="13,8"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="#E2E8F0"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Código do Prod." Binding="{Binding SKU}" Width="120"/>
                    <DataGridTextColumn Header="Nome do Produto" Binding="{Binding Nome}" Width="2*"/>
                    <DataGridTextColumn Header="Categoria" Binding="{Binding Categoria}" Width="1*"/>
                    <DataGridTextColumn Header="Qtd. Atual" Binding="{Binding Quantidade}" Width="100"/>
                    <DataGridTextColumn Header="Preço Unit." Binding="{Binding Preco, StringFormat=C}" Width="120"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="130"/>
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,10,0,0">
                <Button Content="◀ Anterior" Padding="8,4" Background="White" BorderBrush="#CCD" Margin="0,0,5,0"/>
                <Border Background="#3498DB" CornerRadius="4" Width="30" Height="30" Margin="2,0">
                    <TextBlock Text="1" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                </Border>
                <Button Content="2" Width="30" Height="30" Background="White" BorderBrush="#CCD" Margin="2,0"/>
                <Button Content="3" Width="30" Height="30" Background="White" BorderBrush="#CCD" Margin="2,0"/>
                <Button Content="Próximo ▶" Padding="8,4" Background="White" BorderBrush="#CCD" Margin="5,0,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
